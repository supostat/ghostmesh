{
  "$schema": "https://raw.githubusercontent.com/nickel-org/nickel.rs/main/schema.json",
  "productName": "GhostMesh",
  "version": "0.3.0",
  "identifier": "mesh.ghost.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    },
    "windows": [
      {
        "title": "GhostMesh",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENENzg4RjdDNDZDMDFGMEUKUldRT0g4QkdmSTk0emJvZ1ZTb1Q3UG5nQkpHMUNyZUo4OXo5emN6Zkw0cFg5UWt0VGpkWU1lKzAK",
      "endpoints": [
        "https://github.com/supostat/ghostmesh/releases/latest/download/latest.json"
      ]
    }
  }
}
